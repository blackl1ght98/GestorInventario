@using GestorInventario.ViewModels.Notification
@model NotificationViewmodel

@{
    bool sinNotificaciones = Model.Notificaciones == null || !Model.Notificaciones.Any();
    bool todasLeidas = !sinNotificaciones && Model.Notificaciones.All(n => n.Leida);
}

@if (sinNotificaciones)
{
    <div class="text-center text-muted py-4">
        <i class="bi bi-bell-slash"></i>
        <div class="small mt-1">Sin notificaciones</div>
    </div>
}
else if (todasLeidas)
{
    <div class="text-center text-muted py-4">
        <i class="bi bi-check2-all"></i>
        <div class="small mt-1">Ya has leído todas tus notificaciones</div>
    </div>
}
else
{
    foreach (var notificacion in Model.Notificaciones)
    {
        <div class="dropdown-item-text p-3 border-bottom notificacion-item
            @(notificacion.Leida ? "" : "bg-light")"
             data-id="@notificacion.Id"
             style="cursor: pointer; white-space: normal;">

            <div class="d-flex justify-content-between align-items-start mb-1">
                <span class="badge
                    @(notificacion.Tipo == "INFO" ? "bg-info" :
                          notificacion.Tipo == "WARNING" ? "bg-warning text-dark" :
                          notificacion.Tipo == "PAGO" ? "bg-success" :
                          notificacion.Tipo == "STOCK" ? "bg-warning text-dark" :
                          notificacion.Tipo == "REEMBOLSO" ? "bg-secondary" :
                          "bg-secondary")">
                    @notificacion.Tipo
                </span>
                @if (!notificacion.Leida)
                {
                    <span class="badge bg-danger">Nueva</span>
                }
            </div>

            <div class="fw-semibold text-truncate" style="max-width: 100%;">
                @notificacion.Titulo
            </div>
            <div class="small text-muted text-truncate" style="max-width: 100%;">
                @notificacion.Mensaje
            </div>
            <div class="small text-muted mt-1">
                <i class="bi bi-clock"></i>
                @notificacion.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>
    }
}