@using GestorInventario.ViewModels
@model DashboardViewModel

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        text-align: center;
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-4px);
        }

    .card-success {
        border-top: 4px solid #4caf50;
    }

    .card-icon {
        font-size: 32px;
        margin-bottom: 8px;
    }

    .card-value {
        font-size: 42px;
        font-weight: 700;
        color: #2e7d32;
        line-height: 1;
    }

    .card-label {
        color: #666;
        font-size: 14px;
        margin-top: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

<h2>Dashboard</h2>

<div class="dashboard-grid">
    <div class="card card-success">
        <div class="card-icon">💰</div>
        <div class="card-value">@Model.PedidosPagados</div>
        <div class="card-label">Pedidos pagados</div>
    </div>
    <div class="card card-success">
        <div class="card-icon">💰</div>
        <div class="card-value">@Model.PedidosDevueltos</div>
        <div class="card-label">Pedidos devueltos</div>
    </div>
</div>
