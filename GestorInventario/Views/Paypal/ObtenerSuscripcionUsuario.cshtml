@model SuscripcionesUsuarioPaginadosViewModel

@using GestorInventario.ViewModels.Paypal

@{
    ViewData["Title"] = "Suscripciones Activas";
}



<div class="container my-5">
    <div class="text-center mb-4 animate-fade-in">
        <h2 class="text-secondary"><i class="bi bi-wallet me-2"></i>Suscripciones Activas</h2>
        <p class="text-muted">Administra las suscripciones activas de los usuarios en PayPal.</p>
    </div>

    <!-- Mensaje sin datos -->
    @if (Model == null || !Model.Suscripciones.Any())
    {
        <div class="alert alert-warning text-center rounded-3 animate-fade-in">
            <i class="bi bi-exclamation-triangle me-2"></i>No hay suscripciones activas en este momento.
        </div>
    }
    else
    {
        <!-- Lista de Suscripciones con Tarjetas -->
        <div class="row g-4">
            @foreach (var user in Model.Suscripciones)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm hover-card h-100 animate-fade-in">
                        <div class="card-body p-4">
                            <h5 class="card-title mb-3" style="color: var(--primary);">@user.SubscriptionId</h5>
                            <p class="card-text">
                                <i class="bi bi-person nav-icon text-muted"></i> <strong>Usuario:</strong> @user.User.NombreCompleto<br />
                                <i class="bi bi-person-circle nav-icon text-muted"></i> <strong>Nombre Suscriptor:</strong> @user.NombreSusbcriptor<br />
                                <i class="bi bi-key nav-icon text-muted"></i> <strong>ID Suscripción:</strong> @user.SubscriptionId<br />
                                <i class="bi bi-key nav-icon text-muted"></i> <strong>Estado:</strong> @user.Subscription.Status<br />
                                
                            </p>
                        </div>
                        <div class="card-footer bg-light p-3">
                            <div class="d-flex flex-wrap gap-2 justify-content-center">
                                <a asp-action="DetallesSuscripcion" asp-controller="Paypal" asp-route-id="@user.SubscriptionId" class="btn btn-primary btn-sm" data-bs-toggle="tooltip" title="Ver detalles">
                                    <i class="bi bi-eye nav-icon"></i> Detalles
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-danger btn-cancel-suscripcion"
                                        data-id="@user.SubscriptionId"
                                        data-bs-toggle="tooltip"
                                        title="Suspender esta suscripción">
                                    <i class="bi bi-play-fill"></i> Cancelar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }


    <!-- Modal para Cancelar con Motivo -->
    <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="cancelModalLabel"><i class="bi bi-pause-circle me-2"></i>Cancelar Suscripción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <!-- ¡Aquí empieza el formulario real! -->
                <form id="suspendForm" asp-controller="Paypal" asp-action="CancelarSuscripcion" method="post">
                    <div class="modal-body">
                        <p>Ingresa el motivo para cancelar la suscripción <strong id="cancelSubscriptionIdDisplay"></strong>:</p>

                        <!-- Campo oculto para el ID -->
                        <input type="hidden" name="Id" id="cancelSubscriptionId" />

                        <div class="mb-3">
                            <label for="cancelReason" class="form-label">Motivo:</label>
                            <textarea class="form-control"
                                      id="cancelReason"
                                      name="Reason"
                                      rows="4"
                                      placeholder="Escribe el motivo aquí (máximo 500 caracteres)"
                                      maxlength="500"
                                      required></textarea>
                            <div class="invalid-feedback">El motivo es requerido.</div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x me-2"></i>Cancelar
                        </button>
                        <button type="submit" class="btn btn-success" id="confirmABtn">
                            <i class="bi bi-check me-2"></i>Cancelar Subscripcion
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
<!-- Paginación -->
@if (Model.Paginas != null && Model.Paginas.Any())
{
    <nav aria-label="Navegación de páginas" class="mt-5">
        <ul class="pagination justify-content-center">
            @foreach (var pagina in Model.Paginas)
            {
                <li class="page-item @(pagina.Habilitada ? "" : "disabled") @(pagina.Activa ? "active" : "")">
                    <a class="page-link"
                       href="@Url.Action("ObtenerSuscripcionUsuario", new { pagina = pagina.Pagina })"
                       style="transition: background-color 0.2s;">
                        @if (pagina.Texto == "Anterior")
                        {
                            <span aria-hidden="true">«</span>
                        }
                        else if (pagina.Texto == "Siguiente")
                        {
                            <span aria-hidden="true">»</span>
                        }
                        else
                        {
                            @pagina.Texto
                        }
                    </a>
                </li>
            }
        </ul>
    </nav>
}
@section Scripts {

        <script>

            document.addEventListener('DOMContentLoaded', function () {
                 document.querySelectorAll('.btn-cancel-suscripcion').forEach(btn => {
                     btn.addEventListener('click', function () {
                         const subscriptionId = this.getAttribute('data-id');

                         // Rellenar campos
                         document.getElementById('cancelSubscriptionId').value = subscriptionId;
                         document.getElementById('cancelSubscriptionIdDisplay').textContent = subscriptionId;

                         // Limpiar textarea y feedback anterior
                         const reasonInput = document.getElementById('cancelReason');
                         reasonInput.value = '';
                         reasonInput.classList.remove('is-invalid');

                         // Abrir modal
                         const modal = new bootstrap.Modal(document.getElementById('cancelModal'));
                         modal.show();
                     });
                 });
             });
        </script>
}