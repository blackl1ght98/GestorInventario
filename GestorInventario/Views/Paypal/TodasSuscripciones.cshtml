@model SuscripcionesPaginadosViewModel

@using GestorInventario.ViewModels.Paypal
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Suscripciones";
}



<div class="container my-5">
    <div class="text-center mb-4 animate-fade-in">
        <h2 class="text-secondary"><i class="bi bi-wallet me-2"></i>Suscripciones</h2>
        <p class="text-muted">Administra todas las suscripciones de PayPal, revisa detalles y realiza acciones.</p>
    </div>

    <!-- Mensaje de error -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show text-center rounded-3 animate-fade-in" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Mensaje sin datos -->
    @if (Model == null || !Model.Suscripciones.Any())
    {
        <div class="alert alert-warning text-center rounded-3 animate-fade-in">
            <i class="bi bi-exclamation-triangle me-2"></i>No hay suscripciones disponibles en este momento.
        </div>
    }
    else
    {
        <!-- Lista de Suscripciones con Tarjetas -->
        <div class="row g-4">
            @foreach (var user in Model.Suscripciones)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm hover-card h-100 animate-fade-in">
                        <div class="card-body p-4">
                            <h5 class="card-title mb-3" style="color: var(--primary);">@user.SubscriptionId</h5>
                            <p class="card-text">
                                <i class="bi bi-file-text nav-icon text-muted"></i> <strong>Plan ID:</strong> @user.PlanId<br />
                                <i class="bi bi-info-circle nav-icon text-muted"></i> <strong>Estado:</strong>
                                <span class="badge bg-@(user.Status == "ACTIVE" ? "success" : user.Status == "CANCELLED" ? "danger" : "warning")">
                                    @user.Status
                                </span><br />
                                <i class="bi bi-person-badge nav-icon text-muted"></i> <strong>Pagador ID:</strong> @user.PayerId<br />
                                <i class="bi bi-hourglass nav-icon text-muted"></i> <strong>Días de Prueba:</strong>
                                <span id="dias-prueba-@user.SubscriptionId">
                                    @if (user.TrialIntervalCount > 0)
                                    {
                                        @user.TrialIntervalCount
                                    }
                                    else
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    }
                                </span><br />
                                <i class="bi bi-person nav-icon text-muted"></i> <strong>Nombre Suscriptor:</strong> @user.SubscriberName<br />
                                <i class="bi bi-envelope nav-icon text-muted"></i> <strong>Email Suscriptor:</strong> @user.SubscriberEmail<br />
                            </p>
                        </div>
                        @if (User.IsInRole("Administrador"))
                        {
                            <div class="card-footer bg-light p-3">
                                <div class="d-flex flex-wrap gap-2 justify-content-center">
                                    <a asp-action="DetallesSuscripcion" asp-controller="Paypal" asp-route-id="@user.SubscriptionId" class="btn btn-primary btn-sm" data-bs-toggle="tooltip" title="Ver detalles">
                                        <i class="bi bi-eye nav-icon"></i> Detalles
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-danger btn-cancel-suscripcion"
                                            data-id="@user.SubscriptionId"
                                            data-bs-toggle="tooltip"
                                            title="Suspender esta suscripción">
                                        <i class="bi bi-play-fill"></i> Cancelar
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-warning btn-suspend-suscripcion"
                                            data-id="@user.SubscriptionId"
                                            data-bs-toggle="tooltip"
                                            title="Suspender esta suscripción">
                                        <i class="bi bi-play-fill"></i> Suspender
                                    </button>
                                    <!-- Ejemplo dentro de una tabla o card de suscripción -->
                                   <button type="button" 
                                    class="btn btn-sm btn-success btn-activar-suscripcion"
                                    data-id="@user.SubscriptionId"
                                    data-bs-toggle="tooltip" 
                                    title="Activar esta suscripción">
                                <i class="bi bi-play-fill"></i> Activar
                            </button>
                                </div>
                            </div>
                        }
                    </div>
                   
                </div>
            }
        </div>
    }

    <!-- Paginación -->
    @if (Model.Paginas != null && Model.Paginas.Any())
    {
        <nav aria-label="Navegación de páginas" class="mt-5">
            <ul class="pagination justify-content-center">
                @foreach (var pagina in Model.Paginas)
                {
                    <li class="page-item @(pagina.Habilitada ? "" : "disabled") @(pagina.Activa ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("TodasSuscripciones", new { pagina = pagina.Pagina })"
                           style="transition: background-color 0.2s;">
                            @if (pagina.Texto == "Anterior")
                            {
                                <span aria-hidden="true">«</span>
                            }
                            else if (pagina.Texto == "Siguiente")
                            {
                                <span aria-hidden="true">»</span>
                            }
                            else
                            {
                                @pagina.Texto
                            }
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }

    <!-- Modal para Cancelar con Motivo -->
    <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="cancelModalLabel"><i class="bi bi-pause-circle me-2"></i>Cancelar Suscripción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <!-- ¡Aquí empieza el formulario real! -->
                <form id="suspendForm" asp-controller="Paypal" asp-action="CancelarSuscripcion" method="post">
                    <div class="modal-body">
                        <p>Ingresa el motivo para cancelar la suscripción <strong id="cancelSubscriptionIdDisplay"></strong>:</p>

                        <!-- Campo oculto para el ID -->
                        <input type="hidden" name="Id" id="cancelSubscriptionId" />

                        <div class="mb-3">
                            <label for="cancelReason" class="form-label">Motivo:</label>
                            <textarea class="form-control"
                                      id="cancelReason"
                                      name="Reason"
                                      rows="4"
                                      placeholder="Escribe el motivo aquí (máximo 500 caracteres)"
                                      maxlength="500"
                                      required></textarea>
                            <div class="invalid-feedback">El motivo es requerido.</div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x me-2"></i>Cancelar
                        </button>
                        <button type="submit" class="btn btn-success" id="confirmABtn">
                            <i class="bi bi-check me-2"></i>Cancelar Subscripcion
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
<!-- Modal para Suspender con Motivo -->
<div class="modal fade" id="suspendModal" tabindex="-1" aria-labelledby="suspendModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="suspendModalLabel"><i class="bi bi-pause-circle me-2"></i>Suspender Suscripción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <!-- ¡Aquí empieza el formulario real! -->
            <form id="suspendForm" asp-controller="Paypal" asp-action="SuspenderSuscripcion" method="post">
                <div class="modal-body">
                    <p>Ingresa el motivo para suspender la suscripción <strong id="suspendSubscriptionIdDisplay"></strong>:</p>

                    <!-- Campo oculto para el ID -->
                    <input type="hidden" name="Id" id="suspendSubscriptionId" />

                    <div class="mb-3">
                        <label for="suspendReason" class="form-label">Motivo:</label>
                        <textarea class="form-control"
                                  id="suspendReason"
                                  name="Reason"
                                  rows="4"
                                  placeholder="Escribe el motivo aquí (máximo 500 caracteres)"
                                  maxlength="500"
                                  required></textarea>
                        <div class="invalid-feedback">El motivo es requerido.</div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x me-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-success" id="confirmABtn">
                        <i class="bi bi-check me-2"></i>Suspender
                    </button>
                </div>
            </form>
          
        </div>
    </div>
</div>
<!-- Modal para Activar con Motivo -->
<div class="modal fade" id="activateModal" tabindex="-1" aria-labelledby="activateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="activateModalLabel">
                    <i class="bi bi-check-circle me-2"></i>Activar Suscripción
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- ¡Aquí empieza el formulario real! -->
            <form id="activateForm" asp-controller="Paypal" asp-action="ActivarSuscripcion" method="post">
                <div class="modal-body">
                    <p>Ingresa el motivo para activar la suscripción <strong id="activateSubscriptionIdDisplay"></strong>:</p>

                    <!-- Campo oculto para el ID -->
                    <input type="hidden" name="Id" id="activateSubscriptionId" />

                    <div class="mb-3">
                        <label for="activateReason" class="form-label">Motivo:</label>
                        <textarea class="form-control"
                                  id="activateReason"
                                  name="Reason"
                                  rows="4"
                                  placeholder="Escribe el motivo aquí (máximo 500 caracteres)"
                                  maxlength="500"
                                  required></textarea>
                        <div class="invalid-feedback">El motivo es requerido.</div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x me-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-success" id="confirmActivateBtn">
                        <i class="bi bi-check me-2"></i>Activar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        document.addEventListener('DOMContentLoaded', function () {
             document.querySelectorAll('.btn-activar-suscripcion').forEach(btn => {
                 btn.addEventListener('click', function () {
                     const subscriptionId = this.getAttribute('data-id');

                     // Rellenar campos
                     document.getElementById('activateSubscriptionId').value = subscriptionId;
                     document.getElementById('activateSubscriptionIdDisplay').textContent = subscriptionId;

                     // Limpiar textarea y feedback anterior
                     const reasonInput = document.getElementById('activateReason');
                     reasonInput.value = '';
                     reasonInput.classList.remove('is-invalid');

                     // Abrir modal
                     const modal = new bootstrap.Modal(document.getElementById('activateModal'));
                     modal.show();
                 });
             });
         });
    </script>
    <script>

        document.addEventListener('DOMContentLoaded', function () {
             document.querySelectorAll('.btn-suspend-suscripcion').forEach(btn => {
                 btn.addEventListener('click', function () {
                     const subscriptionId = this.getAttribute('data-id');

                     // Rellenar campos
                     document.getElementById('suspendSubscriptionId').value = subscriptionId;
                     document.getElementById('suspendSubscriptionIdDisplay').textContent = subscriptionId;

                     // Limpiar textarea y feedback anterior
                     const reasonInput = document.getElementById('suspendReason');
                     reasonInput.value = '';
                     reasonInput.classList.remove('is-invalid');

                     // Abrir modal
                     const modal = new bootstrap.Modal(document.getElementById('suspendModal'));
                     modal.show();
                 });
             });
         });
    </script>
        <script>

            document.addEventListener('DOMContentLoaded', function () {
                 document.querySelectorAll('.btn-cancel-suscripcion').forEach(btn => {
                     btn.addEventListener('click', function () {
                         const subscriptionId = this.getAttribute('data-id');

                         // Rellenar campos
                         document.getElementById('cancelSubscriptionId').value = subscriptionId;
                         document.getElementById('cancelSubscriptionIdDisplay').textContent = subscriptionId;

                         // Limpiar textarea y feedback anterior
                         const reasonInput = document.getElementById('cancelReason');
                         reasonInput.value = '';
                         reasonInput.classList.remove('is-invalid');

                         // Abrir modal
                         const modal = new bootstrap.Modal(document.getElementById('cancelModal'));
                         modal.show();
                     });
                 });
             });
        </script>
}