@using Newtonsoft.Json
@using System.Globalization
@model GestorInventario.Domain.Models.SubscriptionDetail

@{
    ViewData["Title"] = "Detalles de la Suscripción";

    DateTime trialEndDate = DateTime.MinValue;
    DateTime nextBillingTime = DateTime.MinValue;
    int trialIntervalCount = Model.TrialIntervalCount ?? 0;
    int trialTotalCycles = Model.TrialTotalCycles ?? 0;
    int trialDays = trialIntervalCount > 0 ? trialIntervalCount * trialTotalCycles : 0;

    DateTime startDate = Model.StartTime;
    DateTime statusUpdateDate = Model.StatusUpdateTime;

    if (Model.CyclesCompleted == 1 && Model.CyclesRemaining == 0)
    {
        trialEndDate = startDate.AddDays(trialDays);
        nextBillingTime = trialEndDate.AddDays(1);
    }
}

<div class="container my-5">
    <div class="card shadow border-0">
        <!-- Cabecera -->
        <div class="card-header bg-primary text-white py-4">
            <h2 class="mb-0">
                <i class="bi bi-wallet2 me-3"></i>Detalles de la Suscripción
            </h2>
        </div>

        <div class="card-body p-5">

            <!-- Estado actual (CORREGIDO) -->
            <div class="text-center mb-5 bg-info">
                <span class="badge fs-5 px-5 py-3">
                    <i class="bi bi-circle-fill me-2"></i>@Model.Status
                </span>
            </div>

            <div class="row g-5">

                <!-- Columna Izquierda -->
                <div class="col-lg-6">
                    <h5 class="text-primary border-bottom pb-3 mb-4">
                        <i class="bi bi-info-circle me-2"></i>Información General
                    </h5>
                    <div class="mb-4">
                        <p><strong>ID de la Suscripción:</strong> <span class="text-primary">@Model.SubscriptionId</span></p>
                        <p><strong>ID del Plan:</strong> @Model.PlanId</p>
                    </div>
                    <div class="mb-4">
                        <p><strong>Fecha de Inicio:</strong> @startDate.ToString("dd/MM/yyyy HH:mm:ss")</p>
                        <p>
                            <strong>Fecha de Actualización:</strong>
                            @(statusUpdateDate.Year == 1753 ? "Información no disponible" : statusUpdateDate.ToString("dd/MM/yyyy HH:mm:ss"))
                        </p>
                        <p><strong>Días de Prueba:</strong> @trialDays</p>
                    </div>
                </div>

                <!-- Columna Derecha -->
                <div class="col-lg-6">
                    <h5 class="text-primary border-bottom pb-3 mb-4">
                        <i class="bi bi-person me-2"></i>Detalles del Suscriptor
                    </h5>
                    <div class="mb-4">
                        <p><strong>Nombre:</strong> @Model.SubscriberName</p>
                        <p><strong>Email:</strong> @Model.SubscriberEmail</p>
                        <p><strong>ID del Pagador:</strong> @Model.PayerId</p>
                    </div>
                </div>
            </div>

            <!-- Facturación -->
            <h5 class="text-primary border-bottom pb-3 mb-4 mt-5">
                <i class="bi bi-currency-dollar me-2"></i>Detalles de Facturación
            </h5>

            <div class="row g-4">
                <div class="col-md-6">
                    <p><strong>Balance Pendiente:</strong> @Model.OutstandingBalance @Model.OutstandingCurrency</p>
                    <p>
                        <strong>Próximo Pago:</strong>
                        @(Model.NextBillingTime != DateTime.MinValue
                                                ? Model.NextBillingTime
                                                : "Información no disponible")
                    </p>
                </div>
                <div class="col-md-6">
                    <p>
                        <strong>Último Pago:</strong><br />
                        @if (Model.LastPaymentTime.HasValue && Model.LastPaymentTime.Value.Year > 1753)
                        {
                            <span>@Model.LastPaymentTime.Value.ToString("dd/MM/yyyy HH:mm:ss")</span>
                            <span class="ms-3"><strong>Monto:</strong> @Model.LastPaymentAmount @Model.LastPaymentCurrency</span>
                        }
                        else
                        {
                            <span class="text-muted">No hay información disponible</span>
                        }
                    </p>

                    <p>
                        <strong>Fecha Final de Pago:</strong><br />
                        @if (Model.FinalPaymentTime.Year >= 2030)
                        {
                            <span class="badge bg-info">Suscripción recurrente (sin fecha de finalización)</span>
                        }
                        else if (Model.FinalPaymentTime != DateTime.MinValue && Model.FinalPaymentTime != new DateTime(1753, 1, 1))
                        {
                            @Model.FinalPaymentTime.ToString("dd/MM/yyyy HH:mm:ss")
                        }
                        else
                        {
                            <span class="text-muted">No disponible</span>
                        }
                    </p>
                </div>
            </div>

            <!-- Ciclos y Período de Prueba -->
            @if (Model.CyclesCompleted > 0 || Model.CyclesRemaining > 0 || Model.TotalCycles > 0 || trialDays > 0)
            {
                <div class="mt-5 pt-5 border-top">
                    <h5 class="text-primary border-bottom pb-3 mb-4">
                        <i class="bi bi-arrow-repeat me-2"></i>Detalles del Ciclo
                    </h5>

                    <div class="row text-center g-4">
                        <div class="col-md-4">
                            <div class="bg-light p-4 rounded-3">
                                <p class="text-muted mb-1">Ciclos Completados</p>
                                <h4 class="fw-bold text-success">@Model.CyclesCompleted</h4>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="bg-light p-4 rounded-3">
                                <p class="text-muted mb-1">Ciclos Restantes</p>
                                <h4 class="fw-bold">@Model.CyclesRemaining</h4>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="bg-light p-4 rounded-3">
                                <p class="text-muted mb-1">Total de Ciclos</p>
                                <h4 class="fw-bold">@Model.TotalCycles</h4>
                            </div>
                        </div>
                    </div>

                    @if (trialEndDate != DateTime.MinValue && trialDays > 0)
                    {
                        <div class="mt-5">
                            <h5 class="text-primary mb-4">Período de Prueba</h5>
                            <div class="row text-center g-4">
                                <div class="col-md-4">
                                    <div class="bg-light p-4 rounded-3">
                                        <p class="text-muted mb-1">Días de Prueba</p>
                                        <h4 class="fw-bold text-success">@trialDays</h4>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="bg-light p-4 rounded-3">
                                        <p class="text-muted mb-1">Fin del Período</p>
                                        <h5 class="fw-semibold">@trialEndDate.ToString("dd/MM/yyyy HH:mm:ss")</h5>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="bg-light p-4 rounded-3">
                                        <p class="text-muted mb-1">Primer Cobro</p>
                                        <h5 class="fw-semibold">@nextBillingTime.ToString("dd/MM/yyyy HH:mm:ss")</h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info mt-5">
                    <i class="bi bi-info-circle me-2"></i>No hay detalles del ciclo disponibles.
                </div>
            }
        </div>
    </div>
</div>