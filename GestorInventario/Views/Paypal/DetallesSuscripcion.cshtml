@model GestorInventario.ViewModels.SuscripcionDetalleViewModel

@{
    ViewData["Title"] = "Detalles de la Suscripción";
}

<div class="container my-5">
    <div class="card shadow border-0">
        <!-- Cabecera -->
        <div class="card-header bg-primary text-white py-4">
            <h2 class="mb-0">
                <i class="bi bi-wallet2 me-3"></i>Detalles de la Suscripción
            </h2>
        </div>

        <div class="card-body p-5">

            <!-- Estado actual -->
            <div class="text-center mb-5 bg-info">
                <span class="badge fs-5 px-5 py-3">
                    <i class="bi bi-circle-fill me-2"></i>@Model.Status
                </span>
            </div>

            <div class="row g-5">

                <!-- Columna Izquierda -->
                <div class="col-lg-6">
                    <h5 class="text-primary border-bottom pb-3 mb-4">
                        <i class="bi bi-info-circle me-2"></i>Información General
                    </h5>
                    <div class="mb-4">
                        <p><strong>ID de la Suscripción:</strong> <span class="text-primary">@Model.SubscriptionId</span></p>
                        <p><strong>ID del Plan:</strong> @Model.PlanId</p>
                    </div>
                    <div class="mb-4">
                        <p><strong>Fecha de Inicio:</strong> @Model.StartDate.ToString("dd/MM/yyyy HH:mm:ss")</p>
                        <p>
                            <strong>Fecha de Actualización:</strong>
                            @(Model.StatusUpdateDate.Year == 1753
                                                        ? "Información no disponible"
                                                        : Model.StatusUpdateDate.ToString("dd/MM/yyyy HH:mm:ss"))
                        </p>
                        <p><strong>Días de Prueba:</strong> @Model.TrialDays</p>
                    </div>
                </div>

                <!-- Columna Derecha -->
                <div class="col-lg-6">
                    <h5 class="text-primary border-bottom pb-3 mb-4">
                        <i class="bi bi-person me-2"></i>Detalles del Suscriptor
                    </h5>
                    <div class="mb-4">
                        <p><strong>Nombre:</strong> @Model.SubscriberName</p>
                        <p><strong>Email:</strong> @Model.SubscriberEmail</p>
                        <p><strong>ID del Pagador:</strong> @Model.PayerId</p>
                    </div>
                </div>
            </div>

            <!-- Facturación -->
            <h5 class="text-primary border-bottom pb-3 mb-4 mt-5">
                <i class="bi bi-currency-dollar me-2"></i>Detalles de Facturación
            </h5>

            <div class="row g-4">
                <div class="col-md-6">
                    <p><strong>Balance Pendiente:</strong> @Model.OutstandingBalance @Model.OutstandingCurrency</p>
                    <p>
                      
                        <strong>Próximo Pago:</strong>
                        @(Model.NextBillingTime.HasValue
                                                ? Model.NextBillingTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                                : "Información no disponible")
                    </p>
                </div>
                <div class="col-md-6">
                    <p>
                        <strong>Último Pago:</strong><br />
                        @if (Model.LastPaymentTime.HasValue && Model.LastPaymentTime.Value.Year > 1753)
                        {
                            <span>@Model.LastPaymentTime.Value.ToString("dd/MM/yyyy HH:mm:ss")</span>
                            <span class="ms-3"><strong>Monto:</strong> @Model.LastPaymentAmount @Model.LastPaymentCurrency</span>
                        }
                        else
                        {
                            <span class="text-muted">No hay información disponible</span>
                        }
                    </p>
                    <p>
                        <strong>Fecha Final de Pago:</strong><br />
                        @if (Model.FinalPaymentTime.Year >= 2030)
                        {
                            <span class="badge bg-info">Suscripción recurrente (sin fecha de finalización)</span>
                        }
                        else if (Model.FinalPaymentTime != DateTime.MinValue && Model.FinalPaymentTime != new DateTime(1753, 1, 1))
                        {
                            @Model.FinalPaymentTime.ToString("dd/MM/yyyy HH:mm:ss")
                        }
                        else
                        {
                            <span class="text-muted">No disponible</span>
                        }
                    </p>
                </div>
            </div>
            <!-- Ciclos y Período de Prueba -->
            <!-- Ciclos y Período de Prueba -->
            @if (Model.MostrarCiclos)
            {
                <div class="mt-5 pt-5 border-top">
                    <h5 class="text-primary border-bottom pb-3 mb-4">
                        <i class="bi bi-arrow-repeat me-2"></i>Progreso de la Suscripción
                    </h5>
                    @{
                        var porcentaje = Model.TotalCycles > 0
                        ? (int)Math.Round((decimal)(Model.CyclesCompleted ?? 0) / Model.TotalCycles.Value * 100)
                        : 0;
                    }
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span><strong>@Model.CyclesCompleted</strong> de <strong>@Model.TotalCycles</strong> meses completados</span>
                            <span class="text-muted">@Model.CyclesRemaining meses restantes</span>
                        </div>
                        <div class="progress" style="height: 12px;">
                            <div class="progress-bar bg-success"
                                 style="width: @porcentaje%"
                                 role="progressbar">
                            </div>
                        </div>
                        <small class="text-muted mt-1 d-block">
                            Tu suscripción finaliza el @Model.FinalPaymentTime.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                    @if (Model.EnPeriodoPrueba)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-clock me-2"></i>
                            Estás en tu período de prueba de <strong>@Model.TrialDays días</strong>.
                   
                            Tu primer cobro será el <strong>@Model.NextBillingTime?.ToString("dd/MM/yyyy")</strong>.
                        </div>
                    }
                    else if (Model.MostrarPeriodoPrueba)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-gift me-2"></i>
                            Disfrutaste de <strong>@Model.TrialDays días de prueba</strong>
                           
                            Tu primer cobro fue el <strong>@Model.NextBillingTime?.ToString("dd/MM/yyyy")</strong>.
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info mt-5">
                    <i class="bi bi-info-circle me-2"></i>No hay detalles del ciclo disponibles.
                </div>
            }


        </div>
    </div>
</div>
