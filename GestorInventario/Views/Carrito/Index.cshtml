@model CarritoViewModel
@using GestorInventario.PaginacionLogica
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Carrito de Compras - GestorInventario";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <!-- Título -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <h1 class="display-5 text-primary mb-0">Tu Carrito de Compras</h1>
            </div>

            <!-- Alertas -->
            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="bi bi-info-circle me-2"></i>
                Esta página solo admite pagos vía PayPal. Asegúrate de seleccionar la moneda correcta.
            </div>

            <div class="alert alert-warning border-0 shadow-sm mb-4">
                <i class="bi bi-exclamation-triangle me-2"></i>
                El precio total se calcula en PayPal después de hacer clic en <strong>Checkout</strong>.
            </div>

            <!-- Selector de moneda + Checkout -->
            @if (Model.Productos.Any())
            {
                <form asp-action="Checkout" method="post" class="mb-5">
                    <div class="row align-items-end">
                        <div class="col-md-8">
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-currency-exchange"></i>
                                </span>
                                <select name="monedaSeleccionada" asp-items="Model.Monedas" class="form-select form-select-lg"></select>
                            </div>
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-cart-check me-2"></i>Ir a Checkout con PayPal
                            </button>
                        </div>
                    </div>
                </form>
            }

            <!-- Carrito vacío -->
            @if (!Model.Productos.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x display-1 text-muted mb-3"></i>
                    <h4 class="text-muted">Tu carrito está vacío</h4>
                    <a asp-controller="Productos" asp-action="Index" class="btn btn-primary mt-3">
                        <i class="bi bi-shop me-2"></i>Explorar productos
                    </a>
                </div>
            }
            else
            {
                <!-- Lista de productos -->
                <div class="row g-4">
                    @foreach (var item in Model.Productos)
                    {
                        <div class="col-12">
                            <div class="card shadow-sm border-0 hover-card">
                                <div class="row g-0">
                                    <div class="col-md-3">
                                        <img src="@item.Producto.Imagen"
                                             class="img-fluid h-100 object-fit-cover rounded-start"
                                             alt="@item.Producto.NombreProducto"
                                             style="max-height: 180px;">
                                    </div>
                                    <div class="col-md-9">
                                        <div class="card-body d-flex flex-column h-100">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h5 class="card-title">@item.Producto.NombreProducto</h5>
                                                <span class="fw-bold text-success fs-5">@item.Producto.Precio.ToString("C")</span>
                                            </div>
                                            <p class="text-muted small">@item.Producto.Descripcion</p>
                                            <p class="text-muted small">Proveedor: @item.Producto.IdProveedorNavigation?.NombreProveedor</p>

                                            <div class="mt-auto d-flex justify-content-between align-items-end">
                                                <div class="d-flex align-items-center gap-3">
                                                    <form asp-action="Decrementar" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-dash"></i></button>
                                                    </form>
                                                    <span class="fw-bold fs-5">@item.Cantidad</span>
                                                    <form asp-action="Incrementar" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i></button>
                                                    </form>
                                                </div>

                                                <div class="text-end">
                                                    <small class="text-muted">Total</small>
                                                    <h5 class="mb-0">@((item.Producto.Precio * item.Cantidad))</h5>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-footer bg-light border-0 text-end">
                                    <form asp-action="EliminarProductoCarrito" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Resumen de Compra con IVA -->
                <div class="row mt-5 justify-content-end">
                    <div class="col-md-5">
                        <div class="card shadow border-0">
                            <div class="card-body">
                                <h5 class="card-title text-center mb-4">Resumen de Compra</h5>

                                <div class="d-flex justify-content-between mb-2">
                                    <span>Subtotal</span>
                                    <span>@Model.Subtotal.ToString("C")</span>
                                </div>

                                <div class="d-flex justify-content-between mb-2">
                                    <span>IVA (21%)</span>
                                    <span>@Model.Impuestos.ToString("C")</span>
                                </div>

                                <div class="d-flex justify-content-between mb-3">
                                    <span>Envío</span>
                                    <span class="text-success">Gratis</span>
                                </div>

                                <hr>

                                <div class="d-flex justify-content-between fs-4 fw-bold">
                                    <span>Total</span>
                                    <span>@(Model.Total.ToString("C"))</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>