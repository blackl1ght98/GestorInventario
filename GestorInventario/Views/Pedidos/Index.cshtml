@model PedidoViewModel
@using GestorInventario.MetodosExtension
@using GestorInventario.ViewModels.order

@{
    ViewData["Title"] = "Gestión de Pedidos";
}

<div class="container my-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <h1 class="display-5 text-primary mb-0">Pedidos</h1>
    </div>

    <!-- Filtros -->
    <div class="row g-3 mb-5">
        <!-- Filtro por fechas -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form asp-controller="Pedidos" asp-action="Index" method="get" class="row g-3 align-items-end">
                        <div class="col-12 col-sm-5">
                            <label class="form-label fw-medium small">Fecha desde</label>
                            <input type="date" name="fechaInicio" class="form-control" value="@ViewData["FechaInicio"]" />
                        </div>
                        <div class="col-12 col-sm-5">
                            <label class="form-label fw-medium small">Fecha hasta</label>
                            <input type="date" name="fechaFin" class="form-control" value="@ViewData["FechaFin"]" />
                        </div>
                        <div class="col-12 col-sm-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-2"></i>Buscar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Filtro por texto -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form asp-controller="Pedidos" asp-action="Index" method="get" class="row g-3 align-items-end">
                        <div class="col-12 col-sm-8">
                            <label class="form-label fw-medium small">Buscar por número, cliente o estado</label>
                            <input type="text" name="buscar" class="form-control"
                                   placeholder="Ej: #ABC123, Juan Pérez..." value="@ViewData["Buscar"]" />
                        </div>
                        <div class="col-12 col-sm-4">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-2"></i>Buscar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Pedidos -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var pedido in Model.Pedidos)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-card">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title text-primary mb-0">Pedido #@pedido.NumeroPedido</h5>
                            <span class="badge bg-@(pedido.EstadoPedido == "Rembolsado" ? "warning" :
                                                                             pedido.EstadoPedido == "Completado" ? "success" : "primary") fs-6">
                            @pedido.EstadoPedido
                        </span>
                    </div>

                        <p class="card-text mb-1">
                            <strong>Fecha:</strong> @pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                        </p>
                        <p class="card-text mb-1">
                            <strong>Cliente:</strong> @pedido.IdUsuarioNavigation?.NombreCompleto
                        </p>

                    @if (!string.IsNullOrEmpty(pedido.TrackingNumber))
                        {
                            <p class="card-text mb-1">
                                <strong>Seguimiento:</strong> @pedido.TrackingNumber
                            </p>
                            <p class="card-text mb-3">
                                <strong>Transportista:</strong> @pedido.Transportista
                            </p>
                        }

                        <div class="mt-auto pt-3">
                            <div class="d-grid gap-2">
                                <a asp-action="DetallesPedido" asp-route-id="@pedido.Id"
                                   class="btn btn-outline-primary">
                                    <i class="bi bi-eye me-2"></i>Ver Detalles
                                </a>

                                @if (User.IsAdministrador())
                                {
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@pedido.Id"
                                           class="btn btn-outline-secondary flex-fill">
                                            Actualizar
                                        </a>
                                        <button type="button"
                                                class="btn btn-outline-warning flex-fill refund-total-btn"
                                                data-pedido-id="@pedido.Id"
                                                data-currency="@pedido.Currency"
                                                @(pedido.EstadoPedido == "Rembolsado" ? "disabled" : "")>
                                            Rembolsar
                                        </button>
                                    </div>

                                    <button class="btn btn-success activate-action-button mt-2"
                                            data-pedido-id="@pedido.Id"
                                            data-bs-toggle="tooltip"
                                            title="Agregar información de envío">
                                        <i class="bi bi-truck me-2"></i>Agregar Envío
                                    </button>

                                    <div class="d-grid gap-2 mt-2">
                                        <a asp-action="Delete" asp-route-id="@pedido.Id"
                                           class="btn btn-outline-danger">
                                            Eliminar Pedido
                                        </a>
                                        <a asp-action="DetallesPagoEjecutado" asp-route-id="@pedido.OrderId"
                                           class="btn btn-outline-info">
                                            Detalles del Pago
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Paginación -->
    @if (Model.Paginas != null && Model.Paginas.Any())
    {
        <nav aria-label="Navegación de páginas" class="mt-5">
            <ul class="pagination justify-content-center">
                @foreach (var pagina in Model.Paginas)
                {
                    <li class="page-item @(pagina.Habilitada ? "" : "disabled") @(pagina.Activa ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { pagina = pagina.Pagina, buscar = Model.Buscar, fechaInicio = ViewData["FechaInicio"], fechaFin = ViewData["FechaFin"] })">
                            @pagina.Texto
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<!-- Modales (mejorados) -->
<!-- Modal Agregar Info Envío -->
<div class="modal fade" id="agregarEnvioModal" tabindex="-1" aria-labelledby="agregarEnvioModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="agregarEnvioModalLabel">Agregar Información de Envío</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="agregarEnvioForm" method="post" asp-controller="Pedidos" asp-action="AgregarInfoEnvio">
                    <input type="hidden" name="pedidoId" id="pedidoIdInput" />

                    <div class="mb-3">
                        <label class="form-label">Transportista</label>
                        <select class="form-select" name="carrier" id="carrierSelect" required>
                            <option value="">Seleccione transportista...</option>
                            <option value="CORREOS_ES">Correos España</option>
                            <option value="DHL">DHL</option>
                            <option value="FEDEX">FedEx</option>
                            <option value="UPS">UPS</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo de Código de Barras</label>
                        <select class="form-select" name="barcode" id="barcodeSelect" required>
                            <option value="">Seleccione tipo...</option>
                            <option value="UPC_A">UPC-A</option>
                            <option value="EAN_13">EAN-13</option>
                            <option value="EAN_8">EAN-8</option>
                            <option value="CODE_128">CODE-128</option>
                        </select>
                    </div>
                </form>
                <div id="loadingMessageEnvio" class="text-center mt-3 d-none">
                    <div class="spinner-border text-success" role="status"></div>
                    <p class="mt-2">Procesando envío...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="confirmAgregarEnvioBtn">Guardar Información</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Reembolso -->
<div class="modal fade" id="confirmRefundTotalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Confirmar Reembolso Total</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="refundText" class="mb-3">¿Estás seguro de que deseas reembolsar el pedido completo?</p>
                <div id="refundResult" class="alert d-none" role="alert"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-danger" id="confirmRefundTotalBtn">Sí, Reembolsar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/agregar-info-envio.js" asp-append-version="true"></script>
    <script src="~/js/rembolso.js" asp-append-version="true"></script>
}