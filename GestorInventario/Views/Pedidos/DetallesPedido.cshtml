@model Pedido
<link rel="stylesheet" href="~/css/detallePedido.css" />

<div class="container my-5">
    <div class="card shadow border-0 hover-card">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="h4 mb-0">Detalles del Pedido #@Model.NumeroPedido</h1>
                <span class="badge bg-light text-dark fs-6">
                    @Model.EstadoPedido
                </span>
            </div>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <p><strong>Fecha del pedido:</strong> @Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Cliente:</strong> @Model.IdUsuarioNavigation?.NombreCompleto</p>
                </div>
                <div class="col-md-6 text-md-end">
                    @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                    {
                        <p><strong>Nº de seguimiento:</strong> @Model.TrackingNumber</p>
                        <p><strong>Transportista:</strong> @Model.Transportista</p>
                    }
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-end">Precio Unitario</th>
                            <th class="text-end">Subtotal (sin IVA)</th>
                            <th class="text-end">IVA (21%)</th>
                            <th class="text-end">Total con IVA</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detalle in Model.DetallePedidos)
                        {
                            var precioUnitario = detalle.Producto?.Precio ?? 0;
                            var subtotalSinIva = detalle.Cantidad * precioUnitario;
                            var iva = subtotalSinIva * 0.21m;
                            var totalConIva = subtotalSinIva + iva;

                            <tr>
                                <td>
                                    <strong>@detalle.Producto?.NombreProducto</strong>
                                    <small class="text-muted d-block">@detalle.Producto?.Descripcion</small>
                                </td>
                                <td class="text-center fw-bold">@detalle.Cantidad</td>
                                <td class="text-end">@precioUnitario.ToString("C")</td>
                                <td class="text-end">@subtotalSinIva</td>
                                <td class="text-end text-success">@iva</td>
                                <td class="text-end fw-bold">@totalConIva</td>
                                <td class="text-center">
                                    @if (detalle.Rembolsado ?? false)
                                    {
                                        <span class="badge bg-secondary">Reembolsado</span>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline-warning btn-sm refund-btn"
                                                data-bs-toggle="modal"
                                                data-bs-target="#confirmRefundModal"
                                                data-pedido-id="@detalle.Id"
                                                data-currency="@Model.Currency">
                                            <i class="bi bi-arrow-counterclockwise"></i> Reembolsar
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        @{
                            var totalSinIva = Model.DetallePedidos.Sum(d => d.Cantidad * (d.Producto?.Precio ?? 0));
                            var totalIva = totalSinIva * 0.21m;
                            var granTotal = totalSinIva + totalIva;
                        }
                        <tr>
                            <td colspan="3" class="text-end">Totales:</td>
                            <td class="text-end">@totalSinIva</td>
                            <td class="text-end text-success">@totalIva</td>
                            <td class="text-end">@granTotal</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmación de Reembolso Parcial -->
<div class="modal fade" id="confirmRefundModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 shadow">
            <div class="modal-header bg-warning">
                <h5 class="modal-title text-dark">Confirmar Reembolso Parcial</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-4">¿Estás seguro de que deseas reembolsar este producto?</p>

                <div class="mb-3">
                    <label for="refundReason" class="form-label fw-bold">
                        Motivo del reembolso <span class="text-danger">*</span>
                    </label>
                    <select class="form-select" id="refundReason" required>
                        <option value="" disabled selected>Selecciona un motivo...</option>
                        <option value="Producto defectuoso o dañado">Producto defectuoso o dañado</option>
                        <option value="Error en el envío (producto incorrecto)">Error en el envío (producto incorrecto)</option>
                        <option value="Artículo no entregado">Artículo no entregado</option>
                        <option value="Compensación por demora">Compensación por demora</option>
                        <option value="Ajuste por error de precio">Ajuste por error de precio</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>

                <div id="otherReasonContainer" class="mb-3" style="display: none;">
                    <label for="otherReason" class="form-label fw-bold">
                        Especifica el motivo <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="otherReason" rows="3"
                              placeholder="Describe el motivo del reembolso..." maxlength="255"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="confirmRefundBtn">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Confirmar Reembolso
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/rembolso-parcial.js" asp-append-version="true"></script>
}