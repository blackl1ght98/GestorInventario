@{
    ViewData["Title"] = "Verificacion MFA - GestorInventario";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header text-center py-4" style="background: linear-gradient(90deg, var(--primary), #3B82F6); color: white;">
                    <h3 class="mb-0 fw-bold">Verificacion MFA</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-controller="Auth" asp-action="VerifyMfa" method="post">
                        @Html.AntiForgeryToken()

                        <!-- 1. MENSAJE DE ERROR DE MODELSTATE (CÓDIGO INCORRECTO/TENTATIVOS) -->
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fw-bold" style="font-size: 0.9rem;"></div>

                        <!-- 2. MENSAJE DE ERROR DE TEMPDATA (BLOQUEO TOTAL/REINICIO) -->
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                @TempData["ErrorMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                            </div>
                        }

                        <div class="mb-4">
                            <div class="input-group">
                                <span class="input-group-text" style="background-color: var(--background); border-color: var(--secondary);">
                                    <i class="bi bi-envelope" style="color: var(--secondary);"></i>
                                </span>
                                <input type="text" class="form-control form-control-lg" id="codigo" name="codigo"
                                       placeholder="Introduzca el código" required />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between gap-3">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="bi bi-send nav-icon"></i> Comprobar código
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

