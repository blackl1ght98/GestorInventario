@using GestorInventario.ViewModels
@using GestorInventario.ViewModels.Paypal

@model PayPalPaymentDetailViewModel
@{
    ViewData["Title"] = "Factura de Pago - GestorInventario";

    var isRefunded = Model.Refund != null;
    var isPartialRefund = Model.Capture?.Status == "PARTIALLY_REFUNDED";
    var refundDate = Model.Refund?.CreateTime.ToString("dd/MM/yyyy HH:mm");
    var saldoPendiente = isRefunded
        ? Model.Amount.Total - Model.Refund!.Amount
        : (decimal?)null;
}

<div class="container my-5">
    <div class="card shadow border-0 overflow-hidden" style="border-radius: 1rem;">
        <div class="card-body p-5">

            <!-- Encabezado de Factura -->
            <div class="row mb-5 align-items-center">
                <div class="col-md-6">
                    <img src="~/images/logo.png" alt="GestorInventario" style="max-width: 180px;" class="mb-3" />
                    <h2 class="fw-bold text-primary">Factura</h2>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-1"><strong>Fecha:</strong> @Model.CreateTime?.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-1"><strong>ID del Pago:</strong> <span class="text-muted">@Model.Id</span></p>

                    <p class="mb-1">
                        <strong>Estado del pago:</strong>
                        <span class="badge bg-@(Model.Status == "COMPLETED" ? "success" : "warning") fs-6">
                            @Model.Status
                        </span>
                    </p>

                    @if (isRefunded)
                    {
                        <p class="mb-0">
                            <strong>Reembolso:</strong>
                            <span class="badge bg-warning text-dark fs-6">
                                @(isPartialRefund ? "Parcial" : "Total")
                            </span>
                        </p>
                    }
                </div>
            </div>

            <hr class="my-4">

            <!-- Información del Cliente -->
            <div class="row mb-5">
                <div class="col-lg-6">
                    <h5 class="border-bottom pb-2 text-primary">Detalles del Cliente</h5>
                    <table class="table table-borderless">
                        <tr>
                            <th class="ps-0" style="width: 35%;">Nombre:</th>
                            <td>@(Model.Payer?.FirstName) @(Model.Payer?.LastName)</td>
                        </tr>
                        <tr>
                            <th class="ps-0">Email:</th>
                            <td>@Model.Payer?.Email</td>
                        </tr>
                        @if (Model.Shipping != null)
                        {
                            <tr>
                                <th class="ps-0">Dirección de envío:</th>
                                <td>
                                    @Model.Shipping.Line1<br />
                                    @Model.Shipping.City, @Model.Shipping.State @Model.Shipping.PostalCode<br />
                                    @Model.Shipping.CountryCode
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            <!-- Productos -->
            <h5 class="border-bottom pb-2 text-primary mb-3">Productos Adquiridos</h5>
            <div class="table-responsive mb-5">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-end">Precio Unitario</th>
                            <th class="text-end">Impuesto</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null)
                        {
                            foreach (var item in Model.Items)
                            {
                                var totalItem = (item.ItemPrice * item.ItemQuantity) + item.ItemTax;
                                <tr>
                                    <td><strong>@item.ItemName</strong></td>
                                    <td class="text-center">@item.ItemQuantity</td>
                                    <td class="text-end">@item.ItemPrice</td>
                                    <td class="text-end text-success">@item.ItemTax</td>
                                    <td class="text-end fw-bold">@totalItem</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Resumen de Totales -->
            <div class="row justify-content-end">
                <div class="col-lg-5">
                    <div class="card bg-light border-0">
                        <div class="card-body">
                            <h5 class="card-title text-primary mb-4">Resumen de Pago</h5>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal</span>
                                <span>@Model.Amount.ItemTotal.ToString("0.00") @Model.Amount.Currency</span>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Envío</span>
                                <span>@Model.Amount.Shipping.ToString("0.00") @Model.Amount.Currency</span>
                            </div>
                            <span>Impuestos</span>
                            <span>@Model.Amount.Tax.ToString("0.00") @Model.Amount.Currency</span>
                            @if (isRefunded)
                            {
                                <div class="d-flex justify-content-between mb-2 text-warning">
                                    <span>Reembolso del @refundDate</span>
                                    <span>-@Model.Refund!.Amount.ToString("0.00") @Model.Refund.Currency</span>
                                </div>
                            }

                            <hr>

                            @if (isRefunded)
                            {
                                @if (isPartialRefund)
                                {
                                    <div class="d-flex justify-content-between fs-5 fw-bold">
                                        <span>Total neto</span>
                                        <span>@saldoPendiente?.ToString("0.00") @Model.Amount.Currency</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between fs-5 fw-bold text-muted">
                                        <span>Saldo pendiente</span>
                                        <span>0,00 @Model.Amount.Currency</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="d-flex justify-content-between fs-5 fw-bold">
                                    <span>Total Pagado</span>
                                    <span>@Model.Amount.Total.ToString("0.00") @Model.Amount.Currency</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Acciones -->
            <div class="text-center mt-5 pt-4 border-top">
                <a asp-controller="Facturas" asp-action="SendInvoiceByEmail" asp-route-id="@Model.Id"
                   class="btn btn-success btn-lg px-4 me-3">
                    <i class="bi bi-envelope me-2"></i> Enviar por Email
                </a>
                <a asp-controller="Facturas" asp-action="DownloadInvoice" asp-route-id="@Model.Id"
                   class="btn btn-outline-primary btn-lg px-4">
                    <i class="bi bi-download me-2"></i> Descargar PDF
                </a>
            </div>

        </div>
    </div>
</div>